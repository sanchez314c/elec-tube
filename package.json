{
  "name": "electube",
  "version": "1.0.0",
  "description": "First-class YouTube client with grid view and native playback",
  "main": "dist/main/index.js",
  "author": "J. Michaels <software@jasonpaulmichaels.co>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanchez314c/elec-tube.git"
  },
  "bugs": {
    "url": "https://github.com/sanchez314c/elec-tube/issues"
  },
  "homepage": "https://github.com/sanchez314c/elec-tube#readme",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron --no-sandbox .",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron --no-sandbox .",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "googleapis": "^144.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.electube.app",
    "productName": "ElecTube",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Video",
      "icon": "resources/icon.png"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ]
  }
}
